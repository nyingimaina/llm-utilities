<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NotifierHelper.ToastWindow"
        Width="380"
        MinHeight="70"
        MaxHeight="320"
        SizeToContent="Height"
        WindowStartupLocation="Manual"
        SystemDecorations="None"
        ShowInTaskbar="False"
        Topmost="True"
        CanResize="False"
        x:Name="Root">
  <Window.Styles>
    <Style Selector="Window#Root">
      <Setter Property="Background" Value="Transparent"/>
      
    </Style>
  </Window.Styles>

  <Border x:Name="Card"
          CornerRadius="12"
          Margin="8"
          Cursor="Hand"
          PointerPressed="OnCardClicked">
    <Grid ColumnDefinitions="6, *">
      <Border x:Name="AccentStrip"
              Grid.Column="0"
              Width="6"
              CornerRadius="3,0,0,3"/>

      <StackPanel Grid.Column="1"
                  Margin="16,12,16,12"
                  HorizontalAlignment="Stretch">

        <!-- Server + LLM Client line -->
        <TextBlock x:Name="SenderLabel"
                   FontSize="11"
                   Foreground="#99FFFFFF"
                   TextTrimming="CharacterEllipsis"
                   TextWrapping="NoWrap"
                   IsVisible="False"/>

        <!-- Tool name + args line -->
        <TextBlock x:Name="ToolLine"
                   FontSize="13"
                   Foreground="#DDFFFFFF"
                   TextTrimming="CharacterEllipsis"
                   TextWrapping="NoWrap"
                   Margin="0,2,0,0"
                   IsVisible="False"/>

        <!-- Project path line -->
        <TextBlock x:Name="ProjectLine"
                   FontSize="11"
                   Foreground="#88FFFFFF"
                   TextTrimming="CharacterEllipsis"
                   TextWrapping="NoWrap"
                   IsVisible="False"/>

        <!-- Main message / grouped items -->
        <TextBlock x:Name="MessageText"
                   FontSize="13"
                   Foreground="#CCFFFFFF"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0"
                   TextTrimming="WordEllipsis"
                   MaxHeight="80"/>

        <!-- Grouped item list (for grouped notifications) -->
        <StackPanel x:Name="GroupedList"
                    Margin="0,4,0,0"
                    IsVisible="False"/>

        <Border x:Name="ProgressBar"
                Height="3"
                CornerRadius="1.5"
                Margin="0,8,0,0"
                IsVisible="False">
          <Border x:Name="ProgressFill"
                  Width="0"
                  Height="3"
                  CornerRadius="1.5"
                  HorizontalAlignment="Left"/>
        </Border>

        <TextBlock x:Name="ViewMoreText"
                   FontSize="11"
                   Foreground="#66FFFFFF"
                   Text="View More →"
                   Margin="0,6,0,0"
                   HorizontalAlignment="Right"
                   IsVisible="False"/>
      </StackPanel>
    </Grid>
  </Border>
</Window>
